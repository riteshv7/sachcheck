{
  "manifest_version": 3,
  "name": "SachCheck",
  "version": "1.0.0",
  "description": "Real-time Hinglish political fact-checking assistant.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "sidePanel",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://sachcheck-one.vercel.app/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open SachCheck"
  }
}
